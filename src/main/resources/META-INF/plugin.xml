<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>com.purringlabs.gitworktree.git-worktree-manager</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>Git Worktree Manager</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor email="purringlabs@gmail.com" url="https://github.com/MingLu0">Purring Labs</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        Run Claude Code across multiple Git worktrees — without losing context.<br>
        <br>
        Git Worktree Manager creates, lists, and deletes worktrees in a few clicks, and surfaces every Claude Code session across all worktrees of your repo — resumable in one click, right in the IDE terminal.<br>
        <br>
        <b>Why Claude Code + worktrees?</b><br>
        AI agents make parallel feature branches practical, but branch switching kills agent context. Give each Claude session its own worktree and keep every session discoverable and resumable from the IDE.<br>
        <br>
        <b>Features:</b><br>
            <ul>
                <li>View all Claude Code sessions across every worktree, with current-project sessions first and then sorted by recency</li>
                <li>Resume any Claude session in the IDE terminal with one click</li>
                <li>Create worktrees with automatic branch creation</li>
                <li>Auto-open worktrees in new IDE windows</li>
                <li>Delete worktrees with one click</li>
            </ul>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends optional="true" config-file="compose.xml">com.intellij.modules.compose</depends>
    <depends optional="true" config-file="kotlin.xml">org.jetbrains.kotlin</depends>
    <depends>org.jetbrains.plugins.terminal</depends>
    <depends>Git4Idea</depends>
    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.purringlabs.gitworktree.gitworktreemanager.services.InstallIdentityService"/>
        <applicationService serviceImplementation="com.purringlabs.gitworktree.gitworktreemanager.services.TelemetryServiceImpl"/>
        <postStartupActivity implementation="com.purringlabs.gitworktree.gitworktreemanager.services.WorktreeStartupActivity"/>
    </extensions>
</idea-plugin>
